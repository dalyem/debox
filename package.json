{
  "name": "debox",
  "version": "0.1.0",
  "private": true,
  "description": "Debox — a couch-multiplayer party gaming platform. Phones are controllers, the TV is the stage.",
  "scripts": {
    "dev": "next dev",
    "dev:all": "convex dev --once && concurrently -k -n next,convex -c blue,magenta \"next dev\" \"convex dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@clerk/nextjs": "^6.10.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.18.0",
    "framer-motion": "^11.16.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "next": "^15.1.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.4",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
