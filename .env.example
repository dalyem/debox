# ---------------------------------------------------------------------------
# Debox environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Convex -----------------------------------------------------------------
# Created by `npx convex dev`. Points the browser client at your deployment.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Set automatically by the Convex CLI; identifies the active deployment.
CONVEX_DEPLOYMENT=

# --- Clerk (host authentication) -------------------------------------------
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk hosted sign-in / sign-up routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Convex ⇄ Clerk JWT bridge ---------------------------------------------
# Set this in the *Convex* dashboard (Settings → Environment Variables), not here.
# It is the "Issuer" URL of the Clerk JWT template named `convex`.
# CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# --- Platform ---------------------------------------------------------------
# Public base URL used to build share links + QR codes (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to sign guest session tokens. Set in the Convex dashboard.
# Generate with: openssl rand -base64 48
# GUEST_TOKEN_SECRET=replace-me-with-a-long-random-string
